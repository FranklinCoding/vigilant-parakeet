# Server
PORT=3001
NODE_ENV=development

# PostgreSQL — set via Render dashboard in production
DATABASE_URL=postgresql://user:password@localhost:5432/vaultdeal

# CheapShark API — no key required, just rate-limit friendly
CHEAPSHARK_BASE_URL=https://www.cheapshark.com/api/1.0

# Steam Store API — no key required for public endpoints
STEAM_API_BASE_URL=https://store.steampowered.com/api

# Cron schedule — how often to refresh deals (every 2 hours)
DEALS_CRON_SCHEDULE=0 */2 * * *

# How many deals to fetch per cron run
DEALS_FETCH_LIMIT=100

# CORS — comma-separated allowed origins (leave blank to allow all in dev)
CORS_ORIGINS=http://localhost:5173

# Steam Web API Key — needed for library + recently-played features
# Get yours free at: https://steamcommunity.com/dev/apikey
# Without this key, vanity URL resolution falls back to the XML endpoint
# and the Year in Review still works for public profiles.
STEAM_API_KEY=your_steam_api_key_here

# G2A Marketplace API — shows individual seller listings on game pages
# Register at: https://developers.g2a.com  (free merchant account)
# Without these, the G2A section shows "not configured".
# G2A_CLIENT_ID=your_g2a_client_id
# G2A_CLIENT_SECRET=your_g2a_client_secret

# Kinguin Partner API — shows Kinguin seller listings on game pages
# Register at: https://www.kinguin.net/partner  (free partner account)
# Without this, the Kinguin section shows "not configured".
# KINGUIN_API_KEY=your_kinguin_api_key

# Future: Email alerts
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_password
