# Server
PORT=3001
NODE_ENV=development

# PostgreSQL — set via Render dashboard in production
DATABASE_URL=postgresql://user:password@localhost:5432/vaultdeal

# CheapShark API — no key required, just rate-limit friendly
CHEAPSHARK_BASE_URL=https://www.cheapshark.com/api/1.0

# Steam Store API — no key required for public endpoints
STEAM_API_BASE_URL=https://store.steampowered.com/api

# Cron schedule — how often to refresh deals (every 2 hours)
DEALS_CRON_SCHEDULE=0 */2 * * *

# How many deals to fetch per cron run
DEALS_FETCH_LIMIT=100

# CORS — comma-separated allowed origins (leave blank to allow all in dev)
CORS_ORIGINS=http://localhost:5173

# Future: Steam OAuth (not built yet, stubs only)
# STEAM_API_KEY=your_steam_api_key_here
# SESSION_SECRET=your_session_secret_here

# Future: Email alerts (not built yet)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_password
